# Byte-compiled / optimized Python files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.env
.venv
env/
venv/
ENV/

# OS files
.DS_Store
Thumbs.db

# IDE / editors
.vscode/
.idea/
*.swp
*.swo

# Sync tooling
.Syncthing/
.syncthing/

# Logs and temp
*.log
tmp/
temp/
*.tmp

# Reversible delete — never commit the staging area
trash/

# Secrets — keep credentials and tokens out of the repo
secrets/
credentials/

# Reserved for users who opt into a generated-files sibling folder
memory/.generated/
